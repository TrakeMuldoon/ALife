<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             xmlns:vm="clr-namespace:AvaloniaUniv.Core.ViewModels"
             x:Class="AvaloniaUniv.Core.Views.BatchRunnerView"
             x:CompileBindings="False">
  <Design.DataContext>
    <vm:BatchRunnerViewModel />
  </Design.DataContext>

  <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="38" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220" MinWidth="180" />
      <ColumnDefinition Width="*" MinWidth="300" />
      <ColumnDefinition Width="200" MinWidth="160" />
    </Grid.ColumnDefinitions>

    <!-- Header -->
    <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#1A3A5C" Padding="12,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="ALife Universe — Batch Runner"
                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
        <TextBlock Grid.Column="1" Text="{Binding State}"
                   FontSize="12" VerticalAlignment="Center" Foreground="#AAA" Margin="8,0"/>
      </Grid>
    </Border>

    <!-- Left: Controls -->
    <ScrollViewer Grid.Row="1" Grid.Column="0"
                  HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                  Background="#252526">
      <StackPanel Margin="8" Spacing="6">

        <Button Name="ReturnToLauncher" Click="ReturnToLauncher_Click"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
          ← Return to Launcher
        </Button>

        <Separator />

        <Button Name="StartButton" IsEnabled="{Binding CanStartRunner}"
                Click="Start_Click" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" Background="#107C10" Foreground="White">
          ▶ Start
        </Button>
        <Button Name="StopButton" IsEnabled="{Binding CanStopRunner}"
                Click="Stop_Click" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" Background="#C42B1C" Foreground="White">
          ⏹ Stop
        </Button>
        <Button Name="RestartButton" IsEnabled="{Binding CanRestartRunner}"
                Click="Restart_Click" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center">
          ↺ Restart
        </Button>

        <Separator />

        <Border Background="#2D2D30" CornerRadius="4" Padding="8,6">
          <StackPanel Spacing="5">
            <TextBlock Text="PARAMETERS" FontSize="10" FontWeight="Bold"
                       Foreground="#0078D4" LetterSpacing="1"/>

            <TextBlock Text="Scenarios to run:" Foreground="#AAA" FontSize="11"/>
            <TextBox Text="{Binding ExecutionCount}" FontFamily="Consolas"/>

            <TextBlock Text="Max turns per scenario:" Foreground="#AAA" FontSize="11"/>
            <TextBox Text="{Binding MaxTurnCount}" FontFamily="Consolas"/>

            <TextBlock Text="Turn batch size:" Foreground="#AAA" FontSize="11"/>
            <TextBox Text="{Binding TurnBatchCount}" FontFamily="Consolas"/>

            <TextBlock Text="UI update frequency:" Foreground="#AAA" FontSize="11"/>
            <TextBox Text="{Binding UpdateFrequencyCount}" FontFamily="Consolas"/>

            <TextBlock Text="Note: parameter changes take effect on next restart."
                       FontSize="10" FontStyle="Italic" Foreground="#666"
                       TextWrapping="Wrap" Margin="0,4,0,0"/>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- Centre: Console output -->
    <Grid Grid.Row="1" Grid.Column="1" Background="#1E1E1E">
      <Grid.RowDefinitions>
        <RowDefinition Height="24"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Background="#2D2D30" Padding="8,0">
        <TextBlock Text="Console Output" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
      </Border>
      <TextBox Grid.Row="1" Name="ConsoleText"
               Text="{Binding ConsoleLog}"
               CaretIndex="{Binding ConsoleCaretIndex}"
               IsReadOnly="True" TextWrapping="Wrap"
               FontFamily="Consolas" FontSize="12"
               Background="#1E1E1E" Foreground="#DCDCDC"
               BorderThickness="0"/>
    </Grid>

    <!-- Right: Successful seeds -->
    <Grid Grid.Row="1" Grid.Column="2" Background="#1E1E1E">
      <Grid.RowDefinitions>
        <RowDefinition Height="24"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Background="#2D2D30" Padding="8,0">
        <TextBlock Text="Successful Seeds" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
      </Border>
      <TextBox Grid.Row="1" Name="SeedText"
               Text="{Binding SeedLog}"
               IsReadOnly="True" TextWrapping="Wrap"
               FontFamily="Consolas" FontSize="12"
               Background="#1E1E1E" Foreground="#4EC9B0"
               BorderThickness="0"/>
    </Grid>

  </Grid>
</UserControl>
