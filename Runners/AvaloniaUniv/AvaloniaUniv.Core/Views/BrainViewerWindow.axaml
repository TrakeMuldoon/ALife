<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:AvaloniaUniv.Core.Controls"
        xmlns:vm="clr-namespace:AvaloniaUniv.Core.ViewModels"
        x:Class="AvaloniaUniv.Core.Views.BrainViewerWindow"
        x:CompileBindings="False"
        Title="{Binding BrainViewerTitle}"
        Width="800" Height="600"
        MinWidth="400" MinHeight="300"
        Background="#1E1E1E">
  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0" Background="#2D4A6A" Padding="10,7">
      <TextBlock Text="{Binding AgentName}" FontSize="13" FontWeight="Bold" Foreground="White"/>
    </Border>

    <!-- No agent selected -->
    <TextBlock Grid.Row="1"
               Text="No agent selected. Click an agent in the simulation to inspect its brain."
               IsVisible="{Binding !HasSelectedAgent}"
               TextWrapping="Wrap" Foreground="#666" FontStyle="Italic"
               VerticalAlignment="Center" HorizontalAlignment="Center"
               Margin="24"/>

    <!-- Behaviour brain text -->
    <ScrollViewer Grid.Row="1" IsVisible="{Binding HasBehaviourBrain}"
                  VerticalScrollBarVisibility="Auto">
      <TextBlock Text="{Binding AgentBrain}"
                 FontFamily="Consolas" FontSize="12" Foreground="#CCC"
                 TextWrapping="Wrap" Margin="12"/>
    </ScrollViewer>

    <!-- Neural network canvas -->
    <controls:NeuralBrainCanvas Grid.Row="1"
        Agent="{Binding SelectedAgent}"
        TurnCount="{Binding TurnCount}"
        IsVisible="{Binding HasNeuralBrain}"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"/>

  </Grid>
</Window>
