<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             xmlns:vm="clr-namespace:AvaloniaUniv.Core.ViewModels"
             x:Class="AvaloniaUniv.Core.Views.LauncherView"
             x:DataType="vm:LauncherViewModel">
  <Design.DataContext>
    <vm:LauncherViewModel />
  </Design.DataContext>

  <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="50" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0" Background="#1A3A5C" Padding="16,0">
      <TextBlock Text="ALife Universe — Scenario Launcher"
                 FontSize="20" FontWeight="Bold"
                 VerticalAlignment="Center" Foreground="White"/>
    </Border>

    <!-- Main 3-column grid -->
    <Grid Grid.Row="1" Margin="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition MinWidth="200" Width="*" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition MinWidth="260" Width="*" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition MinWidth="220" Width="0.8*" />
      </Grid.ColumnDefinitions>

      <!-- Column 0: Scenario list -->
      <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#2D4A6A" CornerRadius="4,4,0,0" Padding="8,0">
            <TextBlock Text="Available Scenarios" FontWeight="SemiBold"
                       VerticalAlignment="Center" Foreground="White"/>
          </Border>
          <ListBox Name="ScenariosList" Grid.Row="1"
                   ItemsSource="{Binding AvailableScenarios}"
                   SelectionChanged="ScenariosList_SelectionChanged"
                   SelectionMode="Single" Margin="0"/>
        </Grid>
      </Border>

      <!-- Column 2: Description -->
      <Border Grid.Column="2" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#2D4A6A" CornerRadius="4,4,0,0" Padding="8,0">
            <TextBlock Text="Description" FontWeight="SemiBold"
                       VerticalAlignment="Center" Foreground="White"/>
          </Border>
          <TextBox Name="DescriptionText" Grid.Row="1"
                   Text="{Binding SelectedScenarioDescription}"
                   TextWrapping="Wrap" IsReadOnly="True"
                   BorderThickness="0" Margin="4"/>
        </Grid>
      </Border>

      <!-- Column 4: Seeds + controls -->
      <Border Grid.Column="4" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" MinHeight="120" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0" Background="#2D4A6A" CornerRadius="4,4,0,0" Padding="8,0">
            <TextBlock Text="Suggested Seeds" FontWeight="SemiBold"
                       VerticalAlignment="Center" Foreground="White"/>
          </Border>

          <ListBox Name="SeedSuggestions" Grid.Row="1"
                   ItemsSource="{Binding SuggestedSeeds}"
                   SelectionChanged="SeedSuggestions_SelectionChanged"
                   SelectionMode="Single" Margin="0"/>

          <StackPanel Grid.Row="2" Margin="8" Spacing="6">
            <TextBlock Text="Seed:" FontSize="11" Foreground="#AAA"/>
            <TextBox Name="SeedText" Text="{Binding CurrentSeedText}"
                     PlaceholderText="Enter a Numerical Seed Here"/>
            <CheckBox Name="AutoStartScenarioRunner"
                      IsChecked="{Binding AutoStartScenarioRunner}"
                      Content="Auto-start Batch Runner"/>
            <Button Name="LaunchScenarioUI" Click="LaunchGui_Click"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Background="#0078D4" Foreground="White">
              ▶  Launch Scenario Viewer
            </Button>
            <Button Name="LaunchScenarioRunner" Click="LaunchRunner_Click"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
              ⚙  Launch Batch Runner
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
